SUPABASE_URL=https://XXXX.supabase.co
SUPABASE_SERVICE_KEY=eyJh...
FRONTEND_URL=https://ayiti-market-509.onrender.com
PORT=3000

# MonCash (Digicel) — kreye yon app machann sou https://moncashbutton.digicelgroup.com
MONCASH_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MONCASH_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MONCASH_MODE=sandbox
# ⚠️ Nan dashboard machann MonCash ou, mete URL retou (return URL) sa a:
# https://<DOMÈN-BACKEND-OU>/api/boost/moncash/return

# NatCash pa gen API piblik — peman fèt manyèlman, admin konfime apre.
NATCASH_MERCHANT_PHONE=509-XXXX-XXXX

# VAPID keys — jenere yo yon sèl fwa avèk: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_EMAIL=mailto:admin@ayitimarket.ht

# Resend — Imèl tranzaksyonèl (byenveni, vant konfime, boost, nouvo mesaj)
# Kreye yon kont sou https://resend.com, verifye domèn ou, epi jenere yon API key.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM=Ayiti Market <no-reply@ayitimarket.ht>
